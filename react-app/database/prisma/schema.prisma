generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @default(uuid())
  userName           String   @unique
  name               String
  createdAt          DateTime @default(now())
  initialIsFollowing Boolean  @default(false)

  userFollows UserFollows[] @relation("UserFollows")
  followed    UserFollows[] @relation("Followed")
}

model UserFollows {
  id         String   @id @default(uuid())
  userId     String
  followedId String
  createdAt  DateTime @default(now())

  user     User @relation("UserFollows", fields: [userId], references: [id])
  followed User @relation("Followed", fields: [followedId], references: [id])

  @@unique([userId, followedId])
  @@map("user_follows")
}
