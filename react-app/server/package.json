{
  "name": "serv",
  "version": "1.0.0",
  "description": "API for react-app",
  "main": "index.mjs",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "type": "module",
  "scripts": {
    "build": "npx prisma generate --schema=../database/prisma/schema.prisma && tsc",
    "start": "node dist/index.js",
    "dev": "tsx --watch index.ts",
    "prisma:generate": "npx prisma generate --schema=../database/prisma/schema.prisma",
    "prisma:push": "prisma db push",
    "prisma:seed": "prisma db seed"
  },
  "devDependencies": {
    "@prisma/client": "^7.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@types/pg": "^8.20.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "pg": "^8.20.0",
    "zod": "4.3.6"
  }
}
